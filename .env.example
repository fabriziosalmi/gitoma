# Copy this to ~/.gitoma/.env and fill in your values
# Or use: gitoma config set GITHUB_TOKEN=<your-token>

# ── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_fine_grained_token_here

# ── LM Studio (OpenAI-compatible local API) ──────────────────────────────────
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=gemma-4-e2b-it
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_TEMPERATURE=0.3
LM_STUDIO_MAX_TOKENS=4096

# ── Bot Identity ──────────────────────────────────────────────────────────────
BOT_NAME=FabGPT
BOT_EMAIL=fabgpt.inbox@gmail.com
BOT_GITHUB_USER=fabgpt-coder
