# Copy this to ~/.gitoma/.env and fill in your values
# Or use: gitoma config set GITHUB_TOKEN=<your-token>
#
# Sections marked OPTIONAL are opt-in features. Leave them unset to
# preserve the legacy behavior — gitoma silently skips the feature.

# ── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxx

# ── LM Studio (OpenAI-compatible local API) ──────────────────────────────────
LM_STUDIO_BASE_URL=http://100.98.112.23:1234/v1
LM_STUDIO_MODEL=google/gemma-4-e2b
CRITIC_MODEL=google/gemma-4-e2b
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_TEMPERATURE=0.3
LM_STUDIO_MAX_TOKENS=8192

# Set to 1 only when targeting an exo-cluster endpoint that doesn't honor
# Qwen-style /no_think markers OR chat_template_kwargs. Adds the top-level
# `enable_thinking: false` field to chat completions. Harmless on real LM
# Studio (treated as unknown extra) but mandatory on exo for reasoning-
# distilled models. Default off.
# LM_STUDIO_DISABLE_THINKING_TOPLEVEL=1

# ── Bot Identity ──────────────────────────────────────────────────────────────
BOT_NAME=FabGPT
BOT_EMAIL=fabgpt.inbox@gmail.com
BOT_GITHUB_USER=fabgpt-coder

# ── PHASE 7 — auto-diary push (OPTIONAL) ─────────────────────────────────────
# When BOTH GITOMA_DIARY_REPO and GITOMA_DIARY_TOKEN are set, the end of
# every successful `gitoma run` auto-pushes a markdown entry to the diary
# repo. Failures are swallowed (diary is best-effort). Filename includes
# repo + branch slug so parallel runs don't conflict.
# GITOMA_DIARY_REPO=fabgpt-coder/log
# GITOMA_DIARY_TOKEN=github_pat_xxx       # narrow-scope PAT (Contents R/W on the diary repo)

# Allowlist of source-repo patterns (comma-separated, fnmatch wildcards,
# case-insensitive) that PHASE 7 is allowed to write entries for. When
# unset OR empty, ALL repos write entries (backward-compat default-allow).
# Set this whenever you might run gitoma against a private/client repo
# while GITOMA_DIARY_REPO points at a public log — non-matching repos
# silently skip.
# GITOMA_DIARY_REPO_ALLOWLIST=fabriziosalmi/gitoma-bench-*

# ── PHASE 1.5 + 8 — Layer0 cross-run memory (OPTIONAL) ───────────────────────
# When LAYER0_GRPC_URL is set, PHASE 1.5 queries top-K memories pre-planner
# (LLM branch only; skipped on --plan-from-file) and PHASE 8 ingests
# plan + guards + outcome at the end of every successful run. Silent
# fail-open if the server is unreachable.
# LAYER0_GRPC_URL=127.0.0.1:50051         # gRPC host:port (http:// prefix tolerated)
# LAYER0_API_KEY=                         # optional x-api-key when Layer0 auth is on
# LAYER0_TIMEOUT_S=2.0                    # per-call deadline (default 2s)

# When > 0, PHASE 8 ingests guard-fail memories with `ttl_ms = days × 86400000`
# so high-volume guard noise (e.g. flaky-test G14 firings) ages out
# automatically. Pinned + plan-source + outcome memories untouched.
# Default 0 = forever (backward-compat).
# LAYER0_GUARD_TTL_DAYS=0

# ── PHASE 1.6 — semgrep static-analysis context (OPTIONAL) ───────────────────
# When the `semgrep` binary is on PATH, PHASE 1.6 scans the repo and
# injects top-N high-severity findings into the planner prompt. Opt-out
# via GITOMA_PHASE16_OFF=1 even when the binary is present.
# SEMGREP_BIN=semgrep                     # binary name OR absolute path
# SEMGREP_CONFIG=auto                     # --config value (e.g. p/security-audit, local file)
# SEMGREP_TIMEOUT_S=60                    # clamped min 5s
# GITOMA_PHASE16_OFF=1                    # skip PHASE 1.6 even if binary present

# ── G21 — semgrep-regression critic (OPTIONAL, opt-in) ───────────────────────
# Re-scans post-patch and rejects patches that introduced new (rule_id, path)
# fingerprints vs the PHASE 1.6 baseline. Default OFF — adds subprocess
# cost per patch attempt. Severity floor controls which new findings fail
# the critic (default ERROR-only).
# GITOMA_G21_SEMGREP=1
# GITOMA_G21_SEVERITY=error               # error | warning | info

# ── PHASE 1.7 — stack-shape context (OPTIONAL) ───────────────────────────────
# When OCCAM_TREES_URL is reachable AND RepoBrief.stack has >=2 framework
# signals, PHASE 1.7 infers (stack, level), pulls the canonical scaffold,
# and injects missing canonical paths into the planner prompt as additive-
# only hints. Skipped on --plan-from-file.
# OCCAM_TREES_URL=http://localhost:8420   # FastAPI base URL
# GITOMA_PHASE17_OFF=1                    # skip PHASE 1.7 even if server reachable

# ── PHASE 1.8 — trivy supply-chain context (OPTIONAL) ────────────────────────
# When the `trivy` binary is on PATH, PHASE 1.8 scans for dep CVEs +
# secrets + IaC misconfigs and injects top-N into the planner prompt.
# Vuln entries carry the bump-target version inline. Slow on first run
# (downloads vulnerability DB ~5s, cached after).
# TRIVY_BIN=trivy
# TRIVY_TIMEOUT_S=90                      # clamped min 10s for first-run DB download
# GITOMA_PHASE18_OFF=1                    # skip PHASE 1.8 even if binary present

# ── G22 — trivy-regression critic (OPTIONAL, opt-in) ─────────────────────────
# Re-scans post-patch and rejects patches that introduced new (rule_id,
# target) fingerprints vs the PHASE 1.8 baseline. Default OFF — adds
# trivy invocation cost per patch attempt (~10-90s on non-trivial repos).
# Default scope = WHOLE repo (a patch adding an import can pull in a
# vulnerable transitive dep without directly touching the manifest).
# GITOMA_G22_TRIVY=1
# GITOMA_G22_SEVERITY=error               # error | warning | info
# GITOMA_G22_TOUCHED_ONLY=1               # narrow scope to touched files (faster, less correct)
